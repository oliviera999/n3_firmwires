# Copiez ce fichier en .beta-local-test.env (non versionne)
# puis adaptez les valeurs a votre environnement local.

N3_TEST_LOCAL_SERVER_BASE_URL=http://192.168.1.42:8082
N3_TEST_ADMIN_USERNAME=admin
N3_TEST_ADMIN_TOKEN=local_admin_token_change_me

# Option 1: fournir le mot de passe en clair (hash calcule automatiquement via docker run php:8.2-cli)
N3_TEST_ADMIN_PASSWORD=change_me_local_password

# Option 2: fournir directement le hash bcrypt (prioritaire si present)
# N3_TEST_ADMIN_PASSWORD_HASH=$2y$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

N3_TEST_API_KEY=local_api_key_change_me
