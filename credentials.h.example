#pragma once

// IMPORTANT: Ce fichier contient des informations sensibles
// Ne jamais commiter ce fichier (credentials.h) dans le dépôt git !
// Copier ce fichier en credentials.h et remplir les valeurs réelles.
//
// Fichier unique partagé par : n3pp4_2, msp2_5, uploadphotosserver (msp1, n3pp, ffp3).
// ffp5cs utilise son propre include/secrets.h (voir secrets.h.example dans ffp5cs).

// -----------------------------------------------------------------------------
// WiFi — jusqu'à 3 réseaux (macros pour n3pp4_2, msp2_5)
// -----------------------------------------------------------------------------
#define WIFI_SSID1   "VOTRE_SSID_1"
#define WIFI_PASS1   "VOTRE_MOT_DE_PASSE_1"
#define WIFI_SSID2   "VOTRE_SSID_2"
#define WIFI_PASS2   "VOTRE_MOT_DE_PASSE_2"
#define WIFI_SSID3   "VOTRE_SSID_3"
#define WIFI_PASS3   "VOTRE_MOT_DE_PASSE_3"

// -----------------------------------------------------------------------------
// SMTP (alertes mail — n3pp4_2, msp2_5)
// -----------------------------------------------------------------------------
#define SMTP_HOST_ADDR  "smtp.gmail.com"
#define SMTP_PORT_NUM   465
#define SMTP_EMAIL      "votre.email@gmail.com"
#define SMTP_PASSWORD   "votre_mot_de_passe_application"
#define SMTP_DEST       "destinataire@example.com"

// -----------------------------------------------------------------------------
// API serveur IoT (même valeur que API_KEY dans le .env du serveur)
// -----------------------------------------------------------------------------
#define API_KEY         "votre_cle_api"

// -----------------------------------------------------------------------------
// Liste WiFi (pour uploadphotosserver — struct WifiCredential)
// Les macros ci-dessus restent la source ; cette liste reste cohérente.
// -----------------------------------------------------------------------------
struct WifiCredential {
  const char* ssid;
  const char* password;
};

static const WifiCredential WIFI_LIST[] = {
  { WIFI_SSID1, WIFI_PASS1 },
  { WIFI_SSID2, WIFI_PASS2 },
  { WIFI_SSID3, WIFI_PASS3 }
};
#define WIFI_COUNT (sizeof(WIFI_LIST) / sizeof(WIFI_LIST[0]))
