#pragma once

// IMPORTANT: Copier vers credentials.h et remplir les valeurs réelles.
// credentials.h est dans .gitignore (non versionné).

// -----------------------------------------------------------------------------
// WiFi — jusqu'à 3 réseaux
// -----------------------------------------------------------------------------
#define WIFI_SSID1   "VOTRE_SSID_1"
#define WIFI_PASS1   "VOTRE_MOT_DE_PASSE_1"
#define WIFI_SSID2   "VOTRE_SSID_2"
#define WIFI_PASS2   "VOTRE_MOT_DE_PASSE_2"
#define WIFI_SSID3   "VOTRE_SSID_3"
#define WIFI_PASS3   "VOTRE_MOT_DE_PASSE_3"

// -----------------------------------------------------------------------------
// SMTP (alertes mail)
// -----------------------------------------------------------------------------
#define AUTHOR_EMAIL     "votre.email@gmail.com"
#define AUTHOR_PASSWORD  "votre_mot_de_passe_application"

// -----------------------------------------------------------------------------
// Destinataire mail par défaut (si non configuré via interface)
// -----------------------------------------------------------------------------
#define DEFAULT_MAIL_RECIPIENT "destinataire@example.com"

// -----------------------------------------------------------------------------
// API serveur IoT (même valeur que serveur/.env)
// -----------------------------------------------------------------------------
#define API_KEY  "VOTRE_CLE_API_SERVEUR"

// -----------------------------------------------------------------------------
// Liste WiFi (aligné structure WifiCredential du main)
// -----------------------------------------------------------------------------
struct WifiCredential { const char* ssid; const char* password; };
static const WifiCredential WIFI_LIST[] = {
  { WIFI_SSID1, WIFI_PASS1 },
  { WIFI_SSID2, WIFI_PASS2 },
  { WIFI_SSID3, WIFI_PASS3 }
};
#define WIFI_COUNT (sizeof(WIFI_LIST) / sizeof(WIFI_LIST[0]))
