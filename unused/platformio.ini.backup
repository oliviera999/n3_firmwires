; PlatformIO Project Configuration File
;
;   Build options: build flags, source filter
;   Upload options: custom upload port, speed and extra flags
;   Library options: dependencies, extra library storages
;   Advanced options: extra scripting
;
; Please visit documentation for the other options and examples
; https://docs.platformio.org/page/projectconf.html

; =============================================================================
; ENVIRONNEMENT COMMUN - Configuration de base partagée
; =============================================================================
[env:common]
platform = https://github.com/pioarduino/platform-espressif32/releases/download/stable/platform-espressif32.zip
framework = arduino
monitor_speed = 115200

; Configuration du système de fichiers
board_build.filesystem = littlefs

; Flags de compilation communs
build_flags = 
    -DCORE_DEBUG_LEVEL=3 
    -Iinclude 
    -DELEGANTOTA_USE_ASYNC_WEBSERVER=1 
    -DLOG_LEVEL=LOG_DEBUG 
    -DDEBUG_MODE=1 
    -DVERBOSE_LOGGING=1

; Dépendances communes
lib_deps =
    https://github.com/me-no-dev/AsyncTCP.git
    https://github.com/me-no-dev/ESPAsyncWebServer.git
    adafruit/Adafruit Unified Sensor
    adafruit/DHT sensor library
    mobizt/ESP Mail Client
    adafruit/Adafruit GFX Library
    adafruit/Adafruit SSD1306
    https://github.com/PaulStoffregen/OneWire.git
    milesburton/DallasTemperature
    madhephaestus/ESP32Servo
    fbiego/ESP32Time
    bblanchon/ArduinoJson
    https://github.com/ErickSimoes/Ultrasonic.git
    seeed-studio/Grove Ultrasonic Ranger @ ^1.0.1

; =============================================================================
; ENVIRONNEMENT ESP32 DEV - Configuration spécifique ESP32
; =============================================================================
[env:esp32dev]
extends = env:common
board = esp32dev

; Configuration spécifique ESP32
board_build.partitions = partitions_esp32_wroom_ota.csv

; Flags spécifiques ESP32 (hérite des flags communs)
build_flags = 
    ${env:common.build_flags}
    ; Ajoutez ici des flags spécifiques à l'ESP32 si nécessaire

; =============================================================================
; ENVIRONNEMENT ESP32-S3 - Configuration spécifique ESP32-S3
; =============================================================================
[env:esp32-s3-devkitc-1-n16r8v]
extends = env:common
board = esp32-s3-devkitc-1

; Flags spécifiques ESP32-S3 (hérite des flags communs + ajoute BOARD_S3)
build_flags = 
    ${env:common.build_flags}
    -DBOARD_S3

; =============================================================================
; ENVIRONNEMENT DE PRODUCTION - Optimisé pour la taille du firmware
; =============================================================================
[env:esp32dev-prod]
extends = env:common
board = esp32dev
board_build.partitions = partitions_esp32_wroom_ota.csv

; Flags de compilation optimisés pour la production (taille minimale)
build_flags = 
    -DCORE_DEBUG_LEVEL=1
    -DLOG_LEVEL=LOG_ERROR
    -DNDEBUG
    -Os
    -ffunction-sections
    -fdata-sections
    -Wl,--gc-sections
    -fno-exceptions
    -fno-rtti
    -Iinclude
    -DELEGANTOTA_USE_ASYNC_WEBSERVER=1

; Libraries optimisées pour production (suppression des redondances)
lib_deps =
    https://github.com/me-no-dev/AsyncTCP.git
    https://github.com/me-no-dev/ESPAsyncWebServer.git
    adafruit/Adafruit Unified Sensor
    adafruit/DHT sensor library
    mobizt/ESP Mail Client
    adafruit/Adafruit GFX Library
    adafruit/Adafruit SSD1306
    https://github.com/PaulStoffregen/OneWire.git
    milesburton/DallasTemperature
    madhephaestus/ESP32Servo
    fbiego/ESP32Time
    bblanchon/ArduinoJson
    https://github.com/ErickSimoes/Ultrasonic.git
    seeed-studio/Grove Ultrasonic Ranger @ ^1.0.1

; =============================================================================
; ENVIRONNEMENT ESP32-S3 PRODUCTION - Optimisé pour la taille du firmware
; =============================================================================
[env:esp32-s3-prod]
extends = env:esp32dev-prod
board = esp32-s3-devkitc-1

; Flags spécifiques ESP32-S3 pour production
build_flags = 
    ${env:esp32dev-prod.build_flags}
    -DBOARD_S3

; =============================================================================
; ENVIRONNEMENT DE TEST (optionnel, décommenté si nécessaire)
; =============================================================================
;[env:test-esp32]
;extends = env:esp32-s3-devkitc-1-n16r8v
;build_flags = 
;    ${env:esp32-s3-devkitc-1-n16r8v.build_flags}
;    -DUNIT_TEST
