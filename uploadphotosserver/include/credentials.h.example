#ifndef CREDENTIALS_H
#define CREDENTIALS_H

// Copier ce fichier en credentials.h et remplir les identifiants WiFi.
// Ne jamais versionner credentials.h.
// SERVER_NAME et SERVER_PATH sont définis dans config.h selon la cible (msp1/n3pp/ffp3).

struct WifiCredential {
  const char* ssid;
  const char* password;
};

static const WifiCredential WIFI_LIST[] = {
  {"VOTRE_SSID_1", "VOTRE_MOT_DE_PASSE_1"},
  {"VOTRE_SSID_2", "VOTRE_MOT_DE_PASSE_2"},
  {"VOTRE_SSID_3", "VOTRE_MOT_DE_PASSE_3"}
};
#define WIFI_COUNT (sizeof(WIFI_LIST) / sizeof(WIFI_LIST[0]))

#endif
